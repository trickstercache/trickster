# Load test sizes — S M L XL
# Usage: make SIZE=M query-range
# -- Note: Each iteration (of query-range) includes a 5s sleep

VIRTUAL_USERS_S=10
BATCH_SIZE_S=10
ITERATIONS_S=1200

# Default size is M, 500 users
VIRTUAL_USERS_M=500
BATCH_SIZE_M=500
ITERATIONS_M=60000

# stress test, 5k users
VIRTUAL_USERS_L=5000
BATCH_SIZE_L=2500
ITERATIONS_L=600000

# extra load test, 10k users
# NOTE: observe few EOF errors from k6, but generally healthy load test
VIRTUAL_USERS_XL=10000
BATCH_SIZE_XL=2500
ITERATIONS_XL=1200000
